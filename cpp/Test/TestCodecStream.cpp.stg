void test<v.typeSuffix>(std::shared_ptr\<Viper::StreamCodecInstancing> const & streamCodecInstancing) {
    auto const encoder{streamCodecInstancing->createEncoder()};
    auto const value{Fuzz::fuzz<v.typeSuffix>()};
    Writer writer{encoder};
    writer.write(value);
    auto const data{encoder->endEncoding()};

    auto const decoder{streamCodecInstancing->createDecoder(data)};
    Reader reader{decoder, definitions()};
    auto const valueDecoded{reader.read<v.typeSuffix>()};

     VIPER_ASSERT(component_tcs, valueDecoded == value);
}

