    auto const blobInfo{db->blobInfo(blobId)};
    VIPER_ASSERT(component_td, blobInfo);
    VIPER_ASSERT(component_td, blobInfo->blobId == blobId);
    VIPER_ASSERT(component_td, blobInfo->blobLayout.representation() == "uchar-1");
    VIPER_ASSERT(component_td, blobInfo->size == 4);

    auto const r_data{db->blob(blobId)};
    VIPER_ASSERT(component_td, r_data.has_value());
    VIPER_ASSERT(component_td, r_data->storage == w_data.storage);

    db->delBlob(blobId);
    blobIds = db->blobIds();
    VIPER_ASSERT(component_td, blobIds.empty());
