void test_Blob_Create(std::shared_ptr\<Database> const & db) {
    Viper::Blob const w_data({1,2,3,4});

    auto blobIds{db->blobIds()};
    VIPER_ASSERT(component_td, blobIds.empty());

    // Blob Create
    auto const blobId{db->createBlob(Viper::BlobLayout(), w_data)};
    blobIds = db->blobIds();
