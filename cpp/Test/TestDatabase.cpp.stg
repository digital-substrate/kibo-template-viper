void test_Blob_Stream(std::shared_ptr\<Database> const & db) {
     Viper::Blob const blob({1,2,3,4,5,6,7,8});
     auto const blobLayout{Viper::BlobLayout{}};

    auto const bs{db->blobStreamCreate(blobLayout, blob.size())};
    db->blobStreamAppend(bs, blob.data(), blob.size());
    auto const blobId{db->blobStreamClose(bs)};

    auto const blobInfo{db->blobInfo(blobId)};
    VIPER_ASSERT(component_td, blobInfo);
    VIPER_ASSERT(component_td, blobInfo->blobId == blobId);
    VIPER_ASSERT(component_td, blobInfo->blobLayout.representation() == "uchar-1");
    VIPER_ASSERT(component_td, blobInfo->size == 8);

    Viper::Blob r_blob(blobInfo->size);
    db->databasing()->readBlob(blobId, &r_blob.storage[0], 4, 0);
    db->databasing()->readBlob(blobId, &r_blob.storage[4], 4, 4);

    VIPER_ASSERT(component_td, blob == r_blob);
    db->delBlob(blobId);
}

void test_Blob_IO(std::shared_ptr\<Database> const & db) {
    Viper::Blob const blob({1,2,3,4,5,6,7,8});
    auto const blobLayout{Viper::BlobLayout{}};
