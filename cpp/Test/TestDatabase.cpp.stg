// MARK: - <a.representation>
namespace <m.namespace>::<a.namespace>::TestDatabase::<a.identifier> {
void test(std::shared_ptr\<Database> const & db) {
    <a.documentType.typeInNamespace> v{Fuzz::fuzz<a.documentType.typeSuffix>()};
    <a.keyType.typeInNamespace> const key{Fuzz::fuzz<a.keyType.typeSuffix>()};

    // Keys
    auto keys{DatabaseAttachments::<a.identifier>::keys(db)};
    VIPER_ASSERT(component_td, keys.empty());

    // Insert
    bool status{DatabaseAttachments::<a.identifier>::set(db, key, v)};
    VIPER_ASSERT(component_td, status);

    auto d{DatabaseAttachments::<a.identifier>::get(db, key)};
    VIPER_ASSERT(component_td, d.has_value());

    // Replace
    v = Fuzz::fuzz<a.documentType.typeSuffix>();
    status = DatabaseAttachments::<a.identifier>::set(db, key, v);
    VIPER_ASSERT(component_td, status);

    d = DatabaseAttachments::<a.identifier>::get(db, key);
    VIPER_ASSERT(component_td, d.has_value());

    // Del
    status = DatabaseAttachments::<a.identifier>::del(db, key);
    VIPER_ASSERT(component_td, status);

    d = DatabaseAttachments::<a.identifier>::get(db, key);
    VIPER_ASSERT(component_td, !d.has_value());

    status = DatabaseAttachments::<a.identifier>::del(db, key);
    VIPER_ASSERT(component_td, !status);

    keys = DatabaseAttachments::<a.identifier>::keys(db);
    VIPER_ASSERT(component_td, keys.empty());
}
} // ns

